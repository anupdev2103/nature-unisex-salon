# ──────────────────────────────────────────────────────────────
# Nature Unisex Salon — Environment Variables
# Copy to `.env` and fill with real values from your Supabase project.
# ──────────────────────────────────────────────────────────────

# Supabase project URL + anon key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service role key — SERVER ONLY, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Storage bucket for invoices + logo
SUPABASE_STORAGE_BUCKET="salon-assets"

# Postgres connection (Project Settings → Database → Connection string)
# Use the POOLED connection (port 6543, pgbouncer) for the app at runtime.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT connection (port 5432) — used only by `prisma migrate`.
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
